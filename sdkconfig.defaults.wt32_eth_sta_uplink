# WT32-ETH01: WiFi STA uplink + Ethernet downlink
# Use with: idf.py -B build_eth_sta -D SDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.defaults.wt32_eth_sta_uplink" build

# Ethernet downlink GPIOs (WT32-ETH01 with LAN8720)
CONFIG_ETH_MDC_GPIO=23
CONFIG_ETH_MDIO_GPIO=18
CONFIG_ETH_PHY_ADDR=1
CONFIG_ETH_PHY_POWER_GPIO=16

# Ethernet driver
CONFIG_ETH_USE_ESP32_EMAC=y

# ESP32 supports 240 MHz
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# --- Performance: optimize for speed instead of size ---
CONFIG_COMPILER_OPTIMIZATION_PERF=y
# CONFIG_COMPILER_OPTIMIZATION_SIZE is not set

# lwIP packet processing hot path in IRAM
CONFIG_LWIP_IRAM_OPTIMIZATION=y
